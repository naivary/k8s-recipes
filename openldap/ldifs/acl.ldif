dn: olcDatabase={1}mdb,cn=config
changetype: modify
replace: olcAccess
olcAccess: {0}to attrs=userPassword,shadowLastChange
  by dn="cn=admin,dc=vfde,dc=com" write
  by dn="uid=admin,ou=users,dc=vfde,dc=com" write
  by anonymous auth
  by self write
  by * none
olcAccess: {1}to * by dn="cn=admin,dc=vfde,dc=com" write
  by dn="uid=admin,ou=users,dc=vfde,dc=com" write
  by * read
olcAccess: {2}to dn.base=""
  by * read
